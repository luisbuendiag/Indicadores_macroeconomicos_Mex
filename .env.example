# Copia este archivo a .env y coloca tus tokens. NUNCA subas .env al repositorio.
# Los tokens son gratuitos y se solicitan en los portales oficiales.

# Token del API de indicadores del INEGI (BIE):
# https://www.inegi.org.mx/servicios/api_indicadores.html
INEGI_TOKEN=

# Token del API SIE de Banco de México:
# https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_TOKEN=
